<div class="d-flex align-items-end justify-content-between mb-3">
  <div>
    <h1 class="h-page-title mb-0">Log entries</h1>
    <div class="text-13 text-secondary mt-1">
      <span class="text-body"><%= @total_count %></span> unique
      <% if @analysis_filter.present? %>
        · <%= link_to "Clear filter", log_entries_path, class: "link-light" %>
      <% end %>
    </div>
    <div class="d-flex flex-wrap gap-2 mt-2">
      <%= log_entry_filter_chip(label: "Analyzed", count: @analyzed_count, filter: "analyzed", active_filter: @analysis_filter) %>
      <%= log_entry_filter_chip(label: "Failed", count: @failed_count, filter: "failed", active_filter: @analysis_filter, variant: "danger") %>
    </div>
  </div>
</div>

<table class="table table-sm table-compact align-middle">
  <thead>
    <tr>
      <th>Container</th>
      <th>Message</th>
      <th class="num">Seen</th>
      <th>Status</th>
      <th>Last seen</th>
    </tr>
  </thead>
  <tbody>
    <% @log_entries.each do |log_entry| %>
      <tr class="table-row-link" onclick="window.location='<%= log_entry_path(log_entry) %>'">
        <td><%= log_entry.source_container %></td>
        <td class="text-truncate log-message-col"><%= log_entry.message %></td>
        <td class="num"><%= log_entry.occurrence_count %></td>
        <td>
          <% case log_entry.analysis_status %>
          <% when "analyzed" %>
            <span class="status-dot status-success" title="Analyzed"></span>
          <% when "failed" %>
            <span class="badge text-bg-danger-subtle" title="<%= log_entry.analysis_error %>">Failed</span>
          <% when "pending", "analyzing" %>
            <span class="status-dot status-muted" title="<%= log_entry.analysis_status.humanize %>"></span>
          <% end %>
        </td>
        <td class="text-secondary"><%= time_ago_in_words(log_entry.last_seen_at) %> ago</td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @log_entries.empty? %>
  <p class="text-13 text-secondary mt-3">No entries match this filter.</p>
<% end %>
