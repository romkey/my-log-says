<div class="d-flex align-items-end justify-content-between mb-3">
  <div class="w-100">
    <h1 class="h-page-title mb-0"><%= @filters.container.presence || "Log entries" %></h1>
    <div class="text-13 text-secondary mt-1">
      <span class="text-body"><%= @results_count %></span> shown ·
      <span class="text-body"><%= @total_count %></span> total
      <% if @filters.active? %>
        · <%= pluralize(@filters.active_count, "filter") %> active · <%= link_to "Clear", log_entries_path, class: "link-light" %>
      <% end %>
      <% if @analysis_excluded_count.positive? %>
        · <span class="text-body"><%= @analysis_excluded_count %></span> excluded from analysis
      <% end %>
    </div>

    <div class="h-section-label mt-3 mb-1">Analysis</div>
    <div class="d-flex flex-wrap gap-2">
      <%= log_entry_filter_chip(filters: @filters, facet: :analysis, value: "analyzed", label: "Analyzed", count: @analysis_counts.fetch("analyzed", 0)) %>
      <%= log_entry_filter_chip(filters: @filters, facet: :analysis, value: "failed", label: "Failed", count: @analysis_counts.fetch("failed", 0), variant: "danger") %>
      <% if @analysis_counts.fetch("excluded", 0).positive? %>
        <%= log_entry_filter_chip(filters: @filters, facet: :analysis, value: "excluded", label: "Excluded", count: @analysis_counts.fetch("excluded", 0)) %>
      <% end %>
    </div>

    <% if @docker_containers.any? %>
      <div class="h-section-label mt-3 mb-1">Analysis by container</div>
      <div class="d-flex flex-wrap gap-2">
        <% @docker_containers.each do |container| %>
          <%= container_analysis_toggle(container, filters: @filters) %>
        <% end %>
      </div>
    <% end %>

    <% if @container_counts.any? %>
      <div class="h-section-label mt-3 mb-1">Container</div>
      <div class="d-flex flex-wrap gap-2">
        <% @container_counts.each do |name, count| %>
          <%= log_entry_filter_chip(filters: @filters, facet: :container, value: name, label: name, count: count) %>
        <% end %>
      </div>
    <% end %>

    <% if @severity_counts.any? %>
      <div class="h-section-label mt-3 mb-1">Severity</div>
      <div class="d-flex flex-wrap gap-2">
        <% @severity_counts.each do |level, count| %>
          <%= log_entry_filter_chip(filters: @filters, facet: :severity, value: level, label: level.humanize, count: count) %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<table class="table table-sm table-compact align-middle">
  <thead>
    <tr>
      <th>Container</th>
      <th>Message</th>
      <th class="num">Seen</th>
      <th>Severity</th>
      <th>Status</th>
      <th>Last seen</th>
    </tr>
  </thead>
  <tbody>
    <% @log_entries.each do |log_entry| %>
      <tr id="log-entry-<%= log_entry.id %>" class="table-row-link log-entry-row" onclick="window.location='<%= log_entry_path(log_entry) %>'">
        <td><%= log_entry.source_container %></td>
        <td class="text-truncate log-message-col"><%= log_entry.message %></td>
        <td class="num"><%= log_entry.occurrence_count %></td>
        <td><%= log_entry_severity_label(log_entry) %></td>
        <td>
          <% case log_entry.analysis_status %>
          <% when "analyzed" %>
            <span class="status-dot status-success" title="Analyzed"></span>
          <% when "failed" %>
            <span class="badge text-bg-danger-subtle" title="<%= log_entry.analysis_error %>">Failed</span>
          <% when "pending", "analyzing" %>
            <span class="status-dot status-muted" title="<%= log_entry.analysis_status.humanize %>"></span>
          <% when "excluded" %>
            <span class="badge text-bg-secondary-subtle">Excluded</span>
          <% end %>
        </td>
        <td class="text-secondary"><%= time_ago_in_words(log_entry.last_seen_at) %> ago</td>
      </tr>
    <% end %>
  </tbody>
</table>

<% if @log_entries.empty? %>
  <p class="text-13 text-secondary mt-3">No entries match these filters.</p>
<% end %>
