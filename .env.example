RAILS_ENV=development
# Generate with: bin/rails secret
SECRET_KEY_BASE=change-me

DB_HOST=postgresql
DB_PORT=5432
DB_NAME=loglady_development
DB_USERNAME=loglady
DB_PASSWORD=loglady

REDIS_URL=redis://redis:6379/0

INFERENCE_URL=https://inference.example.com/analyze
INFERENCE_API_KEY=replace-with-real-key
INFERENCE_MODEL=log-analyzer
# API format: loglady (custom POST endpoint) or openai (OpenAI-compatible /v1/chat/completions)
# INFERENCE_API_FORMAT=openai
# INFERENCE_FALLBACK_MODEL=backup-model
INFERENCE_TIMEOUT_SECONDS=30
# Optional: override the prompt saved in the app (Settings) or config/inference_prompt.example.txt
# INFERENCE_PROMPT=You analyze Docker logs...
# INFERENCE_PROMPT_FILE=/path/to/prompt.txt

DOCKER_LOGS_SINCE=10m
# Fold Python-style traceback lines into the preceding log entry (default: true)
# DOCKER_LOG_GROUP_MULTILINE=false
DOCKER_SOCKET=/var/run/docker.sock
# GID of the host docker group — Sidekiq needs this to read the socket.
# Linux: stat -c '%g' /var/run/docker.sock
# macOS: stat -f '%g' /var/run/docker.sock
DOCKER_GID=999
DOCKER_LOG_SYNC_ENABLED=true
DOCKER_LOG_SYNC_CRON="*/1 * * * *"
# Sidekiq thread pools (capsules) — analysis and ingestion run in parallel
SIDEKIQ_ANALYSIS_CONCURRENCY=2
SIDEKIQ_INGESTION_CONCURRENCY=2
# Skip importing logs from LogLady's own containers (default: true)
DOCKER_LOG_SKIP_SELF=true
# LOGLADY_COMPOSE_PROJECT=loglady-dev
# DOCKER_LOG_EXCLUDE_NAMES=loglady,log-lady
# DOCKER_LOG_EXCLUDE_IMAGES=loglady,ghcr.io/romkey/loglady
